# ============================================================
# Unity .gitignore
# ============================================================

# ----- Generated Unity folders ------------------------------
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/

# Asset meta files are tracked – never ignore them
# (removing a .meta breaks Unity's GUID references)

# ----- Unity cache & crash files ----------------------------
*.pidb
*.booproj
*.svd
*.userprefs
*.csproj
*.sln
*.suo
*.tmp
*.unityproj
*.DS_Store
*.orig
crashlytics-build.properties
.consulo/
ExportedObj/
.vs/
.idea/
.vscode/settings.json
.vscode/tasks.json
.vscode/launch.json

# ----- Build outputs ----------------------------------------
*.apk
*.aab
*.unitypackage
*.app
*.exe
*.x86
*.x86_64
*.dll
!Assets/**/*.dll        # keep pre-built plugin DLLs in Assets
*.pdb
*.mdb
*.xml
!Assets/**/*.xml        # keep XML data/config in Assets
*.zip
*.7z
*.tar
*.gz

# ----- Unity Cloud Build ------------------------------------
/UnityCloudBuildManifest.json

# ----- Rider / JetBrains ------------------------------------
.idea/
*.sln.iml

# ----- Visual Studio ----------------------------------------
.vs/
[Ee]xport/
[Ee]xportedObj/
*.pidb.meta
*.pdb.meta
*.mdb.meta
*.vcxproj
*.vcxproj.filters
*.VC.db
*.VC.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.VC.opendb

# ----- MonoDevelop / Xamarin Studio -------------------------
*.userprefs
*.pidb

# ----- Windows ----------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ----- macOS ------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Icon?

# ----- Linux ------------------------------------------------
*~
.directory
.Trash-*

# ----- Node / npm (if using any tooling) --------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----- Python (if using any tooling) ------------------------
__pycache__/
*.pyc
*.pyo

# ----- Shader cache (DX, Metal, Vulkan) ----------------------
ShaderCache/
GPUCache/

# ----- IL2CPP generated code --------------------------------
Il2CppOutputProject/
Assets/Plugins/Editor/JetBrains*

# ----- TextMeshPro (keep Settings & Fonts, skip cache) ------
Assets/TextMesh Pro/Examples & Extras/

# ----- Addressables (generated) -----------------------------
Library/com.unity.addressables/
Assets/AddressableAssetsData/**/AddressableAssetSettings.asset.meta
Assets/StreamingAssets/aa/

# ----- Analytics / Services ---------------------------------
Assets/AssetStoreTools*

# ----- Crash reporting / Backtrace --------------------------
Assets/Plugins/Editor/Backtrace/

# ----- Autogenerated VS/Rider project files -----------------
*.csproj
*.unityproj
*.sln
*.suo
*.user
*.pidb
*.booproj
*.svd

# ----- JetBrains Rider -------------------------------------- 
.idea/
*.sln.iml
.fleet/

# ----- Coverage & test results ------------------------------
/CodeCoverage/
/TestResults/

# ----- Perforce (if mixed VCS environment) ------------------
*.p4ignore

# ----- Level Creation Progression Plans ---------------------
*.md